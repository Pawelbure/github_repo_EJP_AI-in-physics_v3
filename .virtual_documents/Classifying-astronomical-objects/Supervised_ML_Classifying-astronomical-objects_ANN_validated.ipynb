ConfusionMatrixDisplay(cm_norm, display_labels=class_labels).plot(
    ax=axes[1], values_format=".2f", colorbar=False
)
axes[1].set_title("Confusion matrix: row-normalized")
axes[1].tick_params(axis="x", rotation=45)

plt.tight_layout()
